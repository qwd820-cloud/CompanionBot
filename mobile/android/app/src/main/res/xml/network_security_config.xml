<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许局域网 IP 明文通信 (WebSocket to DGX Spark) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
